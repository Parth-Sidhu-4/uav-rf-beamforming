# ==============================================================
# .gitignore — UAV Beamforming Research Project
# Parth Sidhu, Encaptechno Summer Internship 2026
#
# POLICY: Upload code (.py), plots (.png/.svg), datasets
# (.csv/.npy/.npz), models (.pt), assets (.stl/.json),
# and essential repo docs only.
# Everything else is excluded.
# ==============================================================

# --------------------------------------------------------------
# LaTeX — ALL source and build artifacts
# --------------------------------------------------------------
*.tex
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.toc
*.lof
*.lot
*.synctex.gz
*.bcf
*.run.xml

# --------------------------------------------------------------
# PDF — compiled reports and documents
# --------------------------------------------------------------
*.pdf

# --------------------------------------------------------------
# LaTeX backup files
# --------------------------------------------------------------
*.bak
*.bak2
*.bak3
*.tex.bak
*.tex.bak2
*.tex.bak3

# --------------------------------------------------------------
# Plain text files (scratch notes, docstrings, stage logs)
# NOTE: .txt datasets you explicitly want tracked should be
# git-added with --force if needed.
# --------------------------------------------------------------
*.txt

# --------------------------------------------------------------
# Markdown working/planning documents (internal roadmaps etc.)
# The essential repo docs are explicitly kept via exceptions below.
# --------------------------------------------------------------
*.md

# Keep essential GitHub/repo docs — must come AFTER the *.md rule
!README.md
!LICENSE
!DISCLAIMER.md
!CONTRIBUTING.md
!SECURITY.md
!CITATION.cff
!CREDITS.md
!CODE_OF_CONDUCT.md
!EXPORT_CONTROL.md
!NOTICE_CHINA.md
!NOTICE_PAKISTAN_BANGLADESH.md
!NOTICE_GOI_NATIONAL_SECURITY.md
!.gitattributes

# --------------------------------------------------------------
# Python cache and build
# --------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
dist/
build/

# --------------------------------------------------------------
# Virtual environments
# --------------------------------------------------------------
.env
venv/
env/
.venv/
.python-version

# --------------------------------------------------------------
# OS generated junk
# --------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --------------------------------------------------------------
# IDEs and editors
# --------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --------------------------------------------------------------
# Jupyter (if any notebooks exist)
# --------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# --------------------------------------------------------------
# TAG files (generated by ctags etc.)
# --------------------------------------------------------------
*.TAG
tags
